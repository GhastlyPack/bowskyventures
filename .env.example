# Customer.io Track API credentials
# Find these in Customer.io: Settings → Workspace Settings → API Credentials → Track API Keys
CUSTOMERIO_SITE_ID=
CUSTOMERIO_API_KEY=

# Workspace region: "us" (default) or "eu"
CUSTOMERIO_REGION=us

# Optional: override the event name posted on form submit.
# Configure a transactional message / campaign in Customer.io triggered by this event
# to fan out emails to Brandon + the team.
CUSTOMERIO_EVENT_NAME=contact_form_submitted
